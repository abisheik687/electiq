# Environment Variables

# The port for the Express server to run on
PORT=8080

# Your Google Gemini API Key
VITE_GEMINI_KEY=your_gemini_api_key_here

# Your Google Maps API Key
VITE_MAPS_KEY=your_google_maps_api_key_here

# Your Google Civic Information API Key
VITE_CIVIC_API_KEY=your_google_civic_api_key_here

# JWT Secret for authenticating client to server API
JWT_SECRET=your_secure_random_string_here
